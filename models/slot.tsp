import "@typespec/http";

namespace BookingApi;

/**
 * Свободный слот — вычисляемая доступность под выбранный тип события.
 * Не хранится: рассчитывается на лету в окне 14 дней вперёд, круглосуточно,
 * нарезкой встык с шагом, равным длительности типа, минус занятые брони
 * и минус прошедшее время. `end = start + durationMinutes` типа.
 */
model Slot {
  /** Начало слота (UTC, ISO 8601). */
  start: utcDateTime;

  /** Конец слота (UTC, ISO 8601). */
  end: utcDateTime;
}

/** Слоты одного календарного дня (группировка для удобного отображения). */
model DaySlots {
  /** Дата дня в часовом поясе владельца, напр. "2026-06-18". */
  date: plainDate;

  /** Свободные слоты этого дня, по возрастанию времени. */
  slots: Slot[];
}
