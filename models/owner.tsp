import "./common.tsp";

namespace BookingApi;

/**
 * Владелец календаря — единственный заранее заданный профиль.
 * Доступен только на чтение; через API не создаётся, не меняется и не удаляется.
 */
model Owner {
  /** Идентификатор владельца. */
  @key id: string;

  /** Отображаемое имя. */
  name: string;

  /** Контактный e-mail. */
  email: email;

  /**
   * Часовой пояс владельца в формате IANA, напр. "Europe/Moscow".
   * Гость видит время слотов и броней в этом поясе.
   */
  timezone: string;
}
